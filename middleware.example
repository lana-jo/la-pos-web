import { createBrowserClient } from '@supabase/ssr'
import { NextResponse } from 'next/server'
import type { NextRequest } from 'next/server'
import { Database } from '@/types/database'

export async function middleware(req: NextRequest) {
  const res = NextResponse.next()
  
  const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL!
  const supabaseAnonKey = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!
  
  const supabase = createBrowserClient<Database>(supabaseUrl, supabaseAnonKey)

  // Refresh session if expired - required for Server Components
  const {
    data: { session },
  } = await supabase.auth.getSession()

  // Get the pathname of the request (e.g. /, /admin, /pos, /login)
  const path = req.nextUrl.pathname

  // Define public routes that don't require authentication
  const publicRoutes = ['/login', '/register', '/auth/unauthorized']
  const isPublicRoute = publicRoutes.includes(path)

  // Define protected routes and their required roles
  const adminRoutes = ['/admin', '/dashboard']
  const cashierRoutes = ['/pos']
  const customerRoutes = ['/catalog']

  // Check if user is authenticated
  if (!session && !isPublicRoute) {
    // Redirect unauthenticated users to login
    const loginUrl = new URL('/login', req.url)
    return NextResponse.redirect(loginUrl)
  }

  // If user is authenticated, check role-based access
  if (session) {
    // Get user role from profiles table
    const { data: profile, error: profileError } = await supabase
      .from('profiles')
      .select('role')
      .eq('id', session.user.id)
      .single() as { data: { role: 'admin' | 'cashier' | 'customer' } | null, error: any }

    if (profileError || !profile) {
      // If profile doesn't exist, redirect to login
      const loginUrl = new URL('/login', req.url)
      return NextResponse.redirect(loginUrl)
    }

    const userRole = profile.role

    // Check access to admin routes
    if (adminRoutes.some(route => path.startsWith(route))) {
      if (userRole !== 'admin') {
        const unauthorizedUrl = new URL('/auth/unauthorized', req.url)
        return NextResponse.redirect(unauthorizedUrl)
      }
    }

    // Check access to cashier routes (POS)
    if (cashierRoutes.some(route => path.startsWith(route))) {
      if (userRole !== 'cashier' && userRole !== 'admin') {
        const unauthorizedUrl = new URL('/auth/unauthorized', req.url)
        return NextResponse.redirect(unauthorizedUrl)
      }
    }

    // Check access to customer routes
    if (customerRoutes.some(route => path.startsWith(route))) {
      if (userRole !== 'customer' && userRole !== 'admin' && userRole !== 'cashier') {
        const unauthorizedUrl = new URL('/auth/unauthorized', req.url)
        return NextResponse.redirect(unauthorizedUrl)
      }
    }

    // Redirect authenticated users away from auth pages
    if (isPublicRoute) {
      // Redirect based on user role
      if (userRole === 'admin') {
        const dashboardUrl = new URL('/admin/dashboard', req.url)
        return NextResponse.redirect(dashboardUrl)
      } else if (userRole === 'cashier') {
        const posUrl = new URL('/pos', req.url)
        return NextResponse.redirect(posUrl)
      } else if (userRole === 'customer') {
        const catalogUrl = new URL('/catalog', req.url)
        return NextResponse.redirect(catalogUrl)
      }
    }
  }

  return res
}

export const config = {
  matcher: [
    /*
     * Match all request paths except for the ones starting with:
     * - _next/static (static files)
     * - _next/image (image optimization files)
     * - favicon.ico (favicon file)
     * - api (API routes)
     */
    '/((?!_next/static|_next/image|favicon.ico|api).*)',
  ],
}
